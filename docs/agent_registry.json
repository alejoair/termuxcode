{
  "agents": {
    "environment": {
      "file": "core/agents/environment_agent.py",
      "schema": "core/schemas/environment_agent_schema.py",
      "description": "Detecta runtime, dependencias, estructura de directorios y scripts del proyecto.",
      "fields": {
        "project.runtime.language": {
          "schema_field": "runtime_language",
          "type": "str | null",
          "example": "python"
        },
        "project.runtime.version": {
          "schema_field": "runtime_version",
          "type": "str | null",
          "example": "3.14.2"
        },
        "project.runtime.package_manager": {
          "schema_field": "runtime_package_manager",
          "type": "str | null",
          "example": "pip"
        },
        "project.dependencies.main": {
          "schema_field": "dependencies_main",
          "type": "list[str]",
          "example": ["textual==8.0.0", "claude-agent-sdk>=0.1"]
        },
        "project.dependencies.dev": {
          "schema_field": "dependencies_dev",
          "type": "list[str]",
          "example": ["pytest>=7.0.0"]
        },
        "project.structure.entry_point": {
          "schema_field": "structure_entry_point",
          "type": "str | null",
          "example": "src/termuxcode/cli.py"
        },
        "project.structure.source_dir": {
          "schema_field": "structure_source_dir",
          "type": "str | null",
          "example": "src/"
        },
        "project.structure.test_dir": {
          "schema_field": "structure_test_dir",
          "type": "str | null",
          "example": null
        },
        "project.env.required": {
          "schema_field": "env_required",
          "type": "list[str]",
          "example": []
        },
        "project.env.has_dotenv": {
          "schema_field": "env_has_dotenv",
          "type": "bool",
          "example": false
        },
        "project.scripts.run": {
          "schema_field": "scripts_run",
          "type": "str | null",
          "example": "termuxcode"
        },
        "project.scripts.test": {
          "schema_field": "scripts_test",
          "type": "str | null",
          "example": "pytest"
        }
      }
    },
    "architecture": {
      "file": "core/agents/architecture_agent.py",
      "schema": "core/schemas/architecture_agent_schema.py",
      "description": "Mapea módulos del proyecto, sus roles, dependencias internas, entry points, base classes y patrones arquitectónicos.",
      "fields": {
        "project.architecture.modules": {
          "schema_field": "modules",
          "type": "list[str]",
          "example": ["core/memory", "core/agents", "tui"]
        },
        "project.architecture.module_roles": {
          "schema_field": "module_roles",
          "type": "dict (JSON string in schema)",
          "example": {"core/memory": "persistencia key-value y colas", "tui": "terminal UI screens"}
        },
        "project.architecture.entry_points": {
          "schema_field": "entry_points",
          "type": "list[str]",
          "example": ["cli.py", "tui/app.py"]
        },
        "project.architecture.dependencies_map": {
          "schema_field": "dependencies_map",
          "type": "dict (JSON string in schema)",
          "example": {"tui": ["core/agents", "core/memory"], "core/agents": ["core/memory"]}
        },
        "project.architecture.base_classes": {
          "schema_field": "base_classes",
          "type": "list[str]",
          "example": ["BaseAgent", "BaseScreen"]
        },
        "project.architecture.patterns": {
          "schema_field": "patterns",
          "type": "list[str]",
          "example": ["observer en events", "strategy en agents"]
        }
      }
    },
    "overview": {
      "file": "core/agents/overview_agent.py",
      "schema": "core/schemas/overview_agent_schema.py",
      "description": "Builds a comprehensive high-level overview of the project: what it does, why it exists, how to use it, key concepts, and developer onboarding notes.",
      "depends_on": ["environment", "architecture"],
      "fields": {
        "project.overview.name": {
          "schema_field": "name",
          "type": "str | null",
          "example": "termuxcode"
        },
        "project.overview.description": {
          "schema_field": "description",
          "type": "str | null",
          "example": "A mobile-first coding assistant powered by Claude, built with Textual for terminal UI."
        },
        "project.overview.purpose": {
          "schema_field": "purpose",
          "type": "str | null",
          "example": "Enable developers to code from mobile devices using an AI agent with full project context."
        },
        "project.overview.target_platform": {
          "schema_field": "target_platform",
          "type": "str | null",
          "example": "Android/Termux, Windows, Linux"
        },
        "project.overview.tech_stack": {
          "schema_field": "tech_stack",
          "type": "str | null",
          "example": "Python 3.12, Textual 8.0.0, claude-agent-sdk 0.1.48"
        },
        "project.overview.how_to_install": {
          "schema_field": "how_to_install",
          "type": "str | null",
          "example": "git clone ... && cd termuxcode && pip install -e ."
        },
        "project.overview.how_to_run": {
          "schema_field": "how_to_run",
          "type": "str | null",
          "example": "termuxcode"
        },
        "project.overview.how_to_test": {
          "schema_field": "how_to_test",
          "type": "str | null",
          "example": "pytest"
        },
        "project.overview.key_concepts": {
          "schema_field": "key_concepts",
          "type": "list[str]",
          "example": ["Blackboard memory: key-value store that persists project context across sessions"]
        },
        "project.overview.user_facing_features": {
          "schema_field": "user_facing_features",
          "type": "list[str]",
          "example": ["Multi-session chat with tabs", "AI-powered code editing"]
        },
        "project.overview.developer_notes": {
          "schema_field": "developer_notes",
          "type": "str | null",
          "example": "Pydantic schemas must be flat — nested models break StructuredOutput."
        }
      }
    }
  }
}
